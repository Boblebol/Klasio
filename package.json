{
  "name": "klasio",
  "version": "0.1.0",
  "private": true,
  "description": "Outil pour répartir les élèves dans les classes — y compris doubles niveaux. 100% côté client.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Boblebol/Klasio.git"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "python3 -m http.server 8080 --bind 127.0.0.1",
    "build:pages": "node scripts/build-pages.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "vendor:jspdf": "cp node_modules/jspdf/dist/jspdf.umd.min.js vendor/jspdf/jspdf.umd.min.js && cp node_modules/jspdf/LICENSE vendor/jspdf/LICENSE"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "globals": "^15.15.0",
    "jspdf": "^2.5.2",
    "prettier": "^3.8.3",
    "vitest": "^2.1.8"
  }
}
